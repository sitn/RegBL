XLSXW_3_REMOVE_UNCHANGED_TEMPLATE_SHEET "$(XLSXW_OUT_REMOVE_UNCHANGED_TEMPLATE_SHEET_XLSXW_3)"
# Compatibility case to support reading old workspaces which have one template sheet per writer
DEFAULT_MACRO XLSXW_OUT_MULTIPLE_TEMPLATE_SHEETS_XLSXW_3 Yes
XLSXW_3_MULTIPLE_TEMPLATE_SHEETS "$(XLSXW_OUT_MULTIPLE_TEMPLATE_SHEETS_XLSXW_3)"
# Compatibility case to support old case where insert would allow fme_db_operation
DEFAULT_MACRO XLSXW_OUT_INSERT_IGNORE_DB_OP_XLSXW_3 Yes
XLSXW_3_INSERT_IGNORE_DB_OP "$(XLSXW_OUT_INSERT_IGNORE_DB_OP_XLSXW_3)"
# ============================================================================
# Parameters whose values will be percolated to the feature types, but will not
# remain as writer level settings
# Default to not drop feature type first
DEFAULT_MACRO XLSXW_OUT_DROP_TABLE_XLSXW_3 No
XLSXW_3_DROP_TABLE "$(XLSXW_OUT_DROP_TABLE_XLSXW_3)"
# Default to not truncate feature type first (removeallcelldata,retainformatting/headers,etc.)
DEFAULT_MACRO XLSXW_OUT_TRUNCATE_TABLE_XLSXW_3 No
XLSXW_3_TRUNCATE_TABLE "$(XLSXW_OUT_TRUNCATE_TABLE_XLSXW_3)"
# Maintain compatibility with lenient attrName.* matching
DEFAULT_MACRO XLSXW_OUT_STRICT_SCHEMA_ADDITIONAL_ATTRIBUTE_MATCHING_XLSXW_3 yes
XLSXW_3_STRICT_SCHEMA_ADDITIONAL_ATTRIBUTE_MATCHING "$(XLSXW_OUT_STRICT_SCHEMA_ADDITIONAL_ATTRIBUTE_MATCHING_XLSXW_3)"
# Default to write out the field names
DEFAULT_MACRO XLSXW_OUT_FIELD_NAMES_OUT_XLSXW_3 Yes
XLSXW_3_FIELD_NAMES_OUT "$(XLSXW_OUT_FIELD_NAMES_OUT_XLSXW_3)"
# This keyword determines whether we enable creating sheets when only
# receiving a schema feature or not receiving any data.
DEFAULT_MACRO XLSXW_OUT_ALWAYS_CREATE_FEATURE_TYPES_XLSXW_3 NO
XLSXW_3_ALWAYS_CREATE_FEATURE_TYPES "$(XLSXW_OUT_ALWAYS_CREATE_FEATURE_TYPES_XLSXW_3)"
GUI LOOKUP_CHOICE XLSXW_OUT_ALWAYS_CREATE_FEATURE_TYPES_XLSXW_3 YES,YES%NO,NO Always Create Sheets
# Allow header row to be unformatted
DEFAULT_MACRO XLSXW_OUT_FIELD_NAMES_FORMATTING_XLSXW_3 NO
XLSXW_3_FIELD_NAMES_FORMATTING "$(XLSXW_OUT_FIELD_NAMES_FORMATTING_XLSXW_3)"
DEFAULT_MACRO XLSXW_OUT_FIELD_NAMES_ROW_HEIGHT_XLSXW_3 <Unused>
XLSXW_3_FIELD_NAMES_ROW_HEIGHT "$(XLSXW_OUT_FIELD_NAMES_ROW_HEIGHT_XLSXW_3)"
DEFAULT_MACRO XLSXW_OUT_FIELD_NAMES_FONT_NAME_XLSXW_3 <Unused>
XLSXW_3_FIELD_NAMES_FONT_NAME "$(XLSXW_OUT_FIELD_NAMES_FONT_NAME_XLSXW_3)"
DEFAULT_MACRO XLSXW_OUT_FIELD_NAMES_FONT_COLOR_XLSXW_3 <Unused>
XLSXW_3_FIELD_NAMES_FONT_COLOR "$(XLSXW_OUT_FIELD_NAMES_FONT_COLOR_XLSXW_3)"
