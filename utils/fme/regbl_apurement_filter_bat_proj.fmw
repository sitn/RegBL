XLSXW_3_WRITER_MODE "$(XLSXW_OUT_WRITER_MODE_XLSXW_3)"
# Default raster writing type
DEFAULT_MACRO XLSXW_OUT_RASTER_FORMAT_XLSXW_3 PNG
XLSXW_3_RASTER_FORMAT "$(XLSXW_OUT_RASTER_FORMAT_XLSXW_3)"
# ============================================================================
# Choose excel file protection mode
DEFAULT_MACRO XLSXW_OUT_PROTECT_SHEET_XLSXW_3 NO
XLSXW_3_PROTECT_SHEET "$(XLSXW_OUT_PROTECT_SHEET_XLSXW_3)"
# Whether or not to enable sheet password protection
